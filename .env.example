OPENROUTER_API_KEY=
# Model used for generation. Anything OpenRouter serves works.
# See https://openrouter.ai/models for the full list.
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# Optional: how often the background loop (Algorithm 2 — consolidation,
# plasticity, rumination, outreach) fires, in milliseconds. Default 60000.
TICK_INTERVAL_MS=60000
