{
  "name": "humanoid-agent-demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Long-horizon CLI chat surface for humanoid-sdk. OpenRouter for generation; local Xenova/transformers for embeddings; in-memory ground store. A relationship-testing bench, not a production deploy.",
  "scripts": {
    "chat": "tsx src/index.ts",
    "sim": "tsx src/simulate.ts",
    "validate:numerical": "tsx scripts/validate-numerical-stability.ts",
    "validate:repetition": "tsx scripts/validate-repetition-guard.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@humanoid/adapter-cli": "workspace:*",
    "@humanoid/adapter-core": "workspace:*",
    "@humanoid/ground-store": "workspace:*",
    "@humanoid/humanoid": "workspace:*",
    "@humanoid/journal": "workspace:*",
    "@humanoid/primitive": "workspace:*",
    "@humanoid/types": "workspace:*",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^16.4.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=22"
  }
}
